File: lib/mailer.ts

This file creates and exports the Nodemailer transporter.
Keeping it separate means the API route stays clean and
the transport can be reused if other routes need email.

  import nodemailer from 'nodemailer'

  // Validate env vars at module load time — fail loudly
  // in development if misconfigured rather than silently
  // at runtime when a visitor submits the form.
  if (!process.env.GMAIL_USER ||
      !process.env.GMAIL_APP_PASSWORD) {
    console.warn(
      '[mailer] GMAIL_USER or GMAIL_APP_PASSWORD is not set.' +
      ' Contact form emails will fail.'
    )
  }

  export const transporter = nodemailer.createTransport({
    host:   'smtp.gmail.com',
    port:   587,
    secure: false,        // true for 465, false for 587 (STARTTLS)
    auth: {
      user: process.env.GMAIL_USER,
      pass: process.env.GMAIL_APP_PASSWORD,
    },
    tls: {
      rejectUnauthorized: true,   // enforce valid TLS cert
    },
  })

  // Verify transport on startup in development only.
  // Catches wrong credentials before a real visitor hits
  // the form. Never run verify() in production — it adds
  // latency to cold starts.
  if (process.env.NODE_ENV === 'development') {
    transporter.verify((error) => {
      if (error) {
        console.error('[mailer] SMTP connection failed:', error)
      } else {
        console.log('[mailer] Gmail SMTP ready ✓')
      }
    })
  }

  export type MailOptions = {
    to:      string
    subject: string
    html:    string
    text:    string
    replyTo?: string
  }

  export async function sendMail(options: MailOptions):
    Promise<void> {
    await transporter.sendMail({
      from:    `"Portfolio" <${process.env.GMAIL_USER}>`,
      to:      options.to,
      subject: options.subject,
      html:    options.html,
      text:    options.text,
      replyTo: options.replyTo,
    })
  }

